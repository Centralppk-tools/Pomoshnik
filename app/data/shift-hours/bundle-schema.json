{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cppk/shift-templates-bundle",
  "title": "ShiftTemplatesBundle",
  "description": "Корневой файл app/data/shift-templates.json",
  "type": "object",
  "required": ["version", "shiftDetails"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Версия норматива или semver",
      "example": "2026-06-24"
    },
    "generatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "properties": {
        "type": { "const": "local-xlsx" },
        "normativeFrom": { "type": "string", "example": "2026-06-24" },
        "note": { "type": "string" }
      }
    },
    "shiftDetails": {
      "type": "array",
      "items": { "$ref": "flat-row-schema.json" }
    },
    "stats": {
      "type": "object",
      "properties": {
        "rows": { "type": "integer" },
        "routes": { "type": "integer" },
        "markers": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

{
  "version": "1.0.0",
  "description": "Маркеры поля date в shift-templates. Совместимо с SHIFT_WEEKDAY_MARKERS в index.html.",
  "supportedMarkers": [
    "пн", "вт", "ср", "чт", "пт", "сб", "вс",
    "пн-чт", "пн-пт", "пн-пя"
  ],
  "fileNamePatterns": [
    {
      "pattern": "ПН_ЧТ",
      "date": "пн-чт",
      "weekdays": [1, 2, 3, 4],
      "priority": 10
    },
    {
      "pattern": "_ПТ",
      "date": "пт",
      "weekdays": [5],
      "priority": 20,
      "note": "Подстрока _ПТ, чтобы не пересечься с ПН_ЧТ"
    },
    {
      "pattern": "_СБ",
      "date": "сб",
      "weekdays": [6],
      "priority": 20
    },
    {
      "pattern": "_ВС",
      "date": "вс",
      "weekdays": [0],
      "priority": 20
    }
  ],
  "isoDateOverride": {
    "description": "Конкретная дата в имени файла или поле date перекрывает маркер дня",
    "formats": ["yyyy-MM-dd", "dd.MM.yyyy", "dd-MM-yyyy"]
  },
  "normalization": {
    "lowercase": true,
    "dashVariants": ["–", "—", "-"]
  }
}

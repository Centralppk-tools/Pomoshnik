{
  "version": "1.0.0",
  "scope": "shift-hours-only",
  "description": "Правила слияния локальных часов смен с Google API. Графики работы (employees) не затрагиваются.",
  "defaultSource": "local-xlsx",
  "notMergedYet": false,
  "modes": {
    "google-only": {
      "description": "Только Google API для shiftDetails",
      "active": false
    },
    "local-fallback": {
      "description": "Если API недоступен — загрузить app/data/shift-templates.json",
      "active": false
    },
    "local-override": {
      "description": "Локальная база из Часы смен/*.xlsx — основной источник shiftDetails",
      "active": true
    }
  },
  "matchKey": ["date", "route"],
  "priority": ["iso-date", "weekday-marker", "fallback"],
  "localPath": "./data/shift-templates.json",
  "googleFields": {
    "included": ["shiftDetails"],
    "excluded": ["employees", "График работы_Прил"]
  }
}

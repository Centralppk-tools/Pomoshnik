{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cppk/shift-template-row",
  "title": "ShiftTemplateRow",
  "description": "Одна строка shiftDetails — совместима с getShiftDetailsData() и normalizeShiftRecord()",
  "type": "object",
  "required": ["date", "route"],
  "additionalProperties": false,
  "properties": {
    "date": {
      "type": "string",
      "description": "Маркер дня недели или ISO-дата",
      "examples": ["пн-чт", "пт", "сб", "вс", "2026-07-15"]
    },
    "route": {
      "type": "string",
      "description": "Дxx, Нxx или xxУ",
      "examples": ["Д60", "Н60", "61У"]
    },
    "startPlace": {
      "type": "string",
      "examples": ["МЯ", "ЛО", "ПУ"]
    },
    "startTime": {
      "type": "string",
      "pattern": "^\\d{1,2}:\\d{2}$"
    },
    "trains": {
      "type": "string",
      "description": "Номера поездов или текст (приёмка, пасс.)"
    },
    "endTime": {
      "type": "string",
      "pattern": "^\\d{1,2}:\\d{2}$"
    },
    "nightHours": {
      "type": "string"
    },
    "workHours": {
      "type": "string",
      "description": "В приложении маппится в hours"
    },
    "morningRoute": {
      "type": "string",
      "description": "Только для ночных маршрутов Нxx",
      "examples": ["61У"]
    },
    "lunch": {
      "type": "string",
      "enum": ["", "*", "**", "***"]
    }
  }
}
